# =========================
# Smart Flashcard (Monorepo)
# Centralized environment variables for backend + frontend
# Copy to `.env` at repo root and fill values.
# =========================

# ---------- Backend: server ----------
# Port the FastAPI server should run on (when used by your run command)
PORT=8000

# CORS allowlist. Comma-separated origins (no spaces).
# Example: http://localhost:3000,http://127.0.0.1:3000
ALLOWED_ORIGINS=http://localhost:3000

# ---------- Backend: database ----------
DATABASE_URL=postgresql://user:password@localhost:5432/flashcard_db

# Used by `cs50/backend/scripts/migrate_schema_to_supabase.py`
SUPABASE_DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<ref>.supabase.co:5432/postgres?sslmode=require

# ---------- Backend: auth / security ----------
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---------- Backend: OAuth (optional) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------- Backend: AI (optional) ----------
# Used for OpenRouter in this codebase
AI_API_KEY=
AI_MODEL=openai/gpt-3.5-turbo

# ---------- Backend: app ----------
APP_NAME=FastAPI MVP
DEBUG=False

# Study timing thresholds (ms)
FAST_RESPONSE_MS=5000
MEDIUM_RESPONSE_MS=15000

# ---------- Frontend (Vite) ----------
# Base URL for API calls. Recommended in dev: /api/v1 (uses Vite proxy)
# Example for direct backend: http://localhost:8000/api/v1
VITE_BASE_URL=/api/v1

